# immich-auto-stacker — copy to ".env" and set real values.
# Do not commit ".env" with production secrets.

# --- Required ---

# Immich server root (no trailing slash). Alternatively set IMMICH_ENDPOINT (e.g. https://host/api).
IMMICH_SERVER_URL=https://immich.example.com

# API key: Immich Settings > API Keys (scopes: asset.read, stack.*)
IMMICH_API_KEY=your-api-key-here

# Regex: which original filenames participate (JPEG + Fujifilm RAF; case-insensitive)
IMMICH_MATCH=(?i)\.(jpe?g|raf)$

# Regex: stack parent = JPEG (not the RAW)
IMMICH_PARENT=(?i)\.jpe?g$

# --- Optional ---

# IMMICH_ENDPOINT=https://immich.example.com/api
IMMICH_LOG_LEVEL=INFO
IMMICH_COMPARE_CREATED=false
IMMICH_NEWER_THAN=0h
IMMICH_SCAN_INTERVAL=1h
IMMICH_ONCE=false
IMMICH_READ_ONLY=false
IMMICH_DRY_RUN=false
IMMICH_INSECURE_TLS=false
